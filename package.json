{
  "name": "@honeybdg/viewer",
  "version": "1.0.0",
  "description": "UI for viewing images",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "unpkg": "dist/viewer.min.js",
  "license": "MIT",
  "homepage": "https://github.com/honeybdg/viewer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honeybdg/viewer.git"
  },
  "keywords": [
    "ui",
    "viewer",
    "react"
  ],
  "scripts": {
    "dev": "webpack server --mode=development",
    "build": "npm run build:dist && npm run build:lib",
    "build:dist": "webpack --mode=production",
    "build:lib": "babel src --out-dir lib --delete-dir-on-start && tsc",
    "lint": "npm run lint:eslint && npm run lint:stylelint",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint **/*.css"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@honeybdg/codestyle": "^1.0.10",
    "@types/react": "^18.3.31",
    "babel-loader": "^10.1.1",
    "babel-plugin-inline-import": "^3.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
